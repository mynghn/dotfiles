#!/bin/sh


input=$(cat)

if [ -z "$input" ]; then
  input='{}'
fi

echo "$input" | jq '
  .statusLine = {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  } |
  .alwaysThinkingEnabled = true |
  # Opt out of built-in commit/PR instructions + git-status snapshot.
  # Static prompt reduction: ~2k tokens/session (Sonnet), ~2.6k (Opus 4.7 xhigh).
  # Measured on v2.1.117; no cache-prefix invalidation observed.
  .includeGitInstructions = false |
  .enabledPlugins["mgrep@Mixedbread-Grep"] = true |
  .hooks.PreToolUse = [{
    "matcher": "Edit|Write|MultiEdit",
    "hooks": [{"type": "command", "command": "~/.claude/hooks/chezmoi-guard.sh"}]
  }]
'
