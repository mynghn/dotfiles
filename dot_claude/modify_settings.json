#!/bin/sh


input=$(cat)

if [ -z "$input" ]; then
  input='{}'
fi

echo "$input" | jq '
  .statusLine = {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  } |
  .alwaysThinkingEnabled = true |
  # autoConnectIde belongs in ~/.claude.json (global config) per settings.md;
  # placing it here triggers schema validation. Strip any legacy value.
  del(.autoConnectIde) |
  # Disable built-in commit/PR instructions + git-status snapshot injection.
  # The dynamic snapshot busts Anthropic prompt-cache prefix each turn that
  # edits files. See ~/Desktop/include-git-instructions-rationale.md.
  .includeGitInstructions = false |
  .enabledPlugins["mgrep@Mixedbread-Grep"] = true
'
