#!/usr/bin/env bash
# leanplan-selftest: verify validators catch injected defects against LPSYNC-1.
#
# Fixture defaults to the carsharing-backend dogfood artifact; override via
# LEANPLAN_FIXTURE=<path-to-known-good-feature-dir>. Scenarios run in ephemeral
# temp dirs; the fixture is never mutated.

set -uo pipefail

FIXTURE="${LEANPLAN_FIXTURE:-$HOME/nio/workspace/carsharing-backend/docs/features/LPSYNC-1}"
SCRIPT_DIR="$HOME/.claude/scripts"

if [ ! -d "$FIXTURE" ]; then
    echo "error: fixture not found at $FIXTURE (set LEANPLAN_FIXTURE to override)" >&2
    exit 2
fi

TMP=$(mktemp -d)
trap 'rm -rf "$TMP"' EXIT

pass=0
fail=0

assert_case() {
    local label="$1" expected_min_ec="$2" expected_stderr_substr="$3" injection_fn="$4"

    local case_dir="$TMP/docs/features/LPSYNC-1"
    rm -rf "$TMP/docs"
    mkdir -p "$case_dir"
    cp -R "$FIXTURE/." "$case_dir/"

    "$injection_fn" "$case_dir"

    local out ec
    out=$(cd "$TMP" && "$SCRIPT_DIR/leanplan-check" LPSYNC-1 2>&1 >/dev/null)
    ec=$?

    if [ "$ec" -ge "$expected_min_ec" ] && printf '%s' "$out" | grep -qF -- "$expected_stderr_substr"; then
        printf 'PASS %s\n' "$label"
        pass=$((pass + 1))
    else
        printf 'FAIL %s  (expected exit>=%d with stderr ~ %q; got exit=%d)\n' \
            "$label" "$expected_min_ec" "$expected_stderr_substr" "$ec"
        printf '  --- stderr ---\n%s\n  --- end ---\n' "$out"
        fail=$((fail + 1))
    fi
}

inject_baseline() { :; }

inject_broken_anchor() {
    sed -i.bak 's/SPEC#O-1-single-invocation-sync/SPEC#O-99-bogus/g' "$1/task.md"
    rm -f "$1/task.md.bak"
}

inject_coverage_hole() {
    sed -i.bak -E '/SPEC#O-2/d; /O-2 staleness-reporting/d' "$1/task.md"
    rm -f "$1/task.md.bak"
}

inject_req_drift() {
    printf '\nThe system uses Kafka for event streaming.\n' >> "$1/requirement.md"
}

inject_task_step_drift() {
    printf '\n- edit file src/app.ts at line 42 to add config\n' >> "$1/task.md"
}

assert_case "baseline (clean LPSYNC-1)"  0 "anchors=ok"                     inject_baseline
assert_case "V1 broken anchor"           2 "unresolved anchor SPEC#O-99"    inject_broken_anchor
assert_case "V2 coverage hole"           2 "SPEC#O-2 uncovered"             inject_coverage_hole
assert_case "V3 requirement drift"       1 "tech-stack name in requirement" inject_req_drift
assert_case "V3 task step drift"         1 "step-by-step edit instruction"  inject_task_step_drift

printf '\nselftest: %d passed, %d failed\n' "$pass" "$fail"
exit "$fail"
