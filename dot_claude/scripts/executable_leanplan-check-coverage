#!/usr/bin/env bash
# leanplan-check-coverage: bidirectional SPEC ↔ TASK coverage.
#
# Forward:  every SPEC O + INV item is cited at least once in a task.md body.
# Reverse:  every Task's Goal cites at least one SPEC#/DESIGN# anchor.
# Exception: SPEC items appearing on a line containing **GAP** are treated as
#            acknowledged (not reported as uncovered).
#
# Usage: leanplan-check-coverage <KEY>
# Exit:   0 clean / 2 any gap or orphan

set -uo pipefail

KEY="${1:?usage: leanplan-check-coverage <KEY>}"
DIR="docs/features/$KEY"
SPEC="$DIR/spec.md"
TASK="$DIR/task.md"

if [ ! -f "$SPEC" ]; then echo "error: $SPEC not found" >&2; exit 2; fi
if [ ! -f "$TASK" ]; then echo "error: $TASK not found" >&2; exit 2; fi

# SPEC item IDs: O-<N> and INV-<N> from ### headings — only real items
# (slug must be kebab-case; placeholder headings like "### O-1: <kebab-slug>"
# are excluded so scaffolds don't trip the forward check).
spec_ids=$(sed -nE 's/^###[[:space:]]+((O|INV)-[0-9]+):[[:space:]]+[a-z0-9-]+.*/\1/p' "$SPEC" | sort -u)

# Cited IDs: anything referenced as SPEC#O-<N> or SPEC#INV-<N> anywhere in task.md.
cited_ids=$(grep -oE 'SPEC#(O|INV)-[0-9]+' "$TASK" 2>/dev/null | sed 's/SPEC#//' | sort -u)

# Acknowledged gap IDs: IDs appearing on a line containing **GAP**.
ack_ids=$(grep -E '\*\*GAP\*\*' "$TASK" 2>/dev/null | grep -oE '\b(O|INV)-[0-9]+\b' | sort -u)

errors=0

# Forward
for id in $spec_ids; do
    if printf '%s\n' "$cited_ids" | grep -Fxq "$id"; then continue; fi
    if printf '%s\n' "$ack_ids"   | grep -Fxq "$id"; then continue; fi
    printf '%s: error SPEC#%s uncovered by any task Completion\n' "$TASK" "$id" >&2
    errors=$((errors + 1))
done

# Reverse: awk over task.md; each Task must have at least one SPEC#/DESIGN# ref in Goal.
reverse_errors=$(awk -v src="$TASK" '
BEGIN { task = ""; has_ref = 0; in_goal = 0; orphans = 0 }
function flush() {
    if (task != "" && !has_ref) {
        printf "%s: error task %s has no SPEC/DESIGN anchor in Goal\n", src, task > "/dev/stderr"
        orphans++
    }
}
/^## Task:/ {
    flush()
    tmp = $0
    sub(/^## Task:[[:space:]]*/, "", tmp)
    task = tmp
    has_ref = 0
    in_goal = 0
    next
}
/^- \*\*Goal\*\*:/        { in_goal = 1 }
in_goal && /(SPEC|DESIGN)#[A-Za-z]+-[0-9]+-[a-z0-9-]+/ { has_ref = 1 }
/^- \*\*(Repo|Completion|Dependencies|Guidelines)\*\*:/ { in_goal = 0 }
/^---/                   { in_goal = 0 }
END { flush(); print orphans }
' "$TASK")

errors=$((errors + reverse_errors))

[ "$errors" -eq 0 ] && exit 0 || exit 2
