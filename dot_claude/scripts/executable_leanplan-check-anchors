#!/usr/bin/env bash
# leanplan-check-anchors: verify every SPEC#/DESIGN# reference resolves to a heading.
#
# Usage: leanplan-check-anchors <KEY>
# Exit codes:
#   0  clean — every reference resolves
#   2  one or more unresolved references

set -uo pipefail

KEY="${1:?usage: leanplan-check-anchors <KEY>}"
DIR="docs/features/$KEY"

if [ ! -d "$DIR" ]; then
    echo "error: $DIR not found" >&2
    exit 2
fi

defs_file=$(mktemp)
trap 'rm -f "$defs_file"' EXIT

# Collect anchor definitions from SPEC (O + INV at H3) and DESIGN (Decision at H2).
# Convert heading "### O-1: single-invocation-sync" → "SPEC#O-1-single-invocation-sync".
{
    if [ -f "$DIR/spec.md" ]; then
        grep -E '^###[[:space:]]+(O|INV)-[0-9]+:[[:space:]]+[a-z0-9-]+' "$DIR/spec.md" \
            | sed -E 's/^###[[:space:]]+((O|INV)-[0-9]+):[[:space:]]+([a-z0-9-]+)[[:space:]]*$/SPEC#\1-\3/' \
            || true
    fi
    if [ -f "$DIR/design.md" ]; then
        grep -E '^##[[:space:]]+Decision-[0-9]+:[[:space:]]+[a-z0-9-]+' "$DIR/design.md" \
            | sed -E 's/^##[[:space:]]+(Decision-[0-9]+):[[:space:]]+([a-z0-9-]+)[[:space:]]*$/DESIGN#\1-\2/' \
            || true
    fi
} > "$defs_file"

errors=0

# Walk every reference in every .md under the feature dir; check each against defs.
while IFS= read -r hit; do
    [ -z "$hit" ] && continue
    src="${hit%%:*}"
    rest="${hit#*:}"
    lineno="${rest%%:*}"
    content="${rest#*:}"
    # Each line may contain multiple refs; check each unique one.
    for ref in $(printf '%s\n' "$content" | grep -oE '(SPEC|DESIGN)#[A-Za-z]+-[0-9]+-[a-z0-9-]+' | sort -u); do
        if ! grep -Fxq "$ref" "$defs_file"; then
            printf '%s:%s: error unresolved anchor %s\n' "$src" "$lineno" "$ref" >&2
            errors=$((errors + 1))
        fi
    done
done < <(grep -EHnr '(SPEC|DESIGN)#[A-Za-z]+-[0-9]+-[a-z0-9-]+' "$DIR" 2>/dev/null || true)

[ "$errors" -eq 0 ] && exit 0 || exit 2
