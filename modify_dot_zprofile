#!/bin/sh
set -eu

input_file=$(mktemp "${TMPDIR:-/tmp}/chezmoi-zprofile.XXXXXX")
trap 'rm -f "$input_file"' EXIT

cat > "$input_file"

bash_max_output='export BASH_MAX_OUTPUT_LENGTH=20000'
max_mcp_output='export MAX_MCP_OUTPUT_TOKENS=12000'
file_read_max_output='export CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS=20000'

missing_bash_max_output=
missing_max_mcp_output=
missing_file_read_max_output=

if ! grep -qxF "$bash_max_output" "$input_file"; then
  missing_bash_max_output="$bash_max_output"
fi

if ! grep -qxF "$max_mcp_output" "$input_file"; then
  missing_max_mcp_output="$max_mcp_output"
fi

if ! grep -qxF "$file_read_max_output" "$input_file"; then
  missing_file_read_max_output="$file_read_max_output"
fi

cat "$input_file"

if [ -n "$missing_bash_max_output$missing_max_mcp_output$missing_file_read_max_output" ]; then
  if [ -s "$input_file" ]; then
    printf '\n'
  fi

  printf '%s\n' '# Claude Code token-efficiency caps for noisy tool output.'

  if [ -n "$missing_bash_max_output" ]; then
    printf '%s\n' "$missing_bash_max_output"
  fi

  if [ -n "$missing_max_mcp_output" ]; then
    printf '%s\n' "$missing_max_mcp_output"
  fi

  if [ -n "$missing_file_read_max_output" ]; then
    printf '%s\n' "$missing_file_read_max_output"
  fi
fi
